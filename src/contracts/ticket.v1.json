{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xopsconference.com/schemas/ticket.v1.json",
  "title": "Ticket",
  "description": "Schema for a conference ticket tier (v1.0)",
  "type": "object",
  "required": ["id", "name", "price", "currency"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "price": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "enum": ["EUR", "USD"] },
    "available": { "type": "boolean" },
    "maxQuantity": { "type": "integer", "minimum": 0 },
    "features": { "type": "array", "items": { "type": "string" } },
    "purchaseUrl": { "type": "string", "format": "uri" }
  },
  "additionalProperties": false
}
